{% extends 'front/base.html.twig' %}

{% block page_title %}Checkout{% endblock %}

{% block front_body %}
    <section class="checkout-hero text-center mx-auto">
        <p class="eyebrow">Checkout</p>
        <h1>Review your cart before payment.</h1>
        <p>
            Your selected DressMe offers are listed below. Stripe payment will be connected in the next step.
        </p>
    </section>

    <section class="checkout-layout">
        <div class="checkout-main">
            <a class="btn btn-outline-dark rounded-pill px-4 checkout-back-link" href="{{ path('front_offers') }}">Back to offers</a>

            <div class="checkout-panel">
                <div class="checkout-panel__header">
                    <div>
                        <p class="offers-section__kicker mb-1">Cart items</p>
                        <h2 class="mb-0">Selected offers</h2>
                    </div>
                    <span class="checkout-panel__count">
                        <span data-checkout-count>0</span> item(s)
                    </span>
                </div>

                <p class="checkout-empty" data-checkout-empty>
                    Your cart is empty. Add an offer before continuing to payment.
                    <a href="{{ path('front_offers') }}">Back to offers</a>
                </p>

                <div class="checkout-table-wrap">
                    <table class="checkout-table">
                        <thead>
                            <tr>
                                <th scope="col">Offer</th>
                                <th scope="col">Unit price</th>
                                <th scope="col">Qty</th>
                                <th scope="col">Subtotal</th>
                                <th scope="col"><span class="visually-hidden">Actions</span></th>
                            </tr>
                        </thead>
                        <tbody data-checkout-list></tbody>
                    </table>
                </div>

                <template data-checkout-item-template>
                    <tr data-checkout-item>
                        <td>
                            <strong data-checkout-item-name></strong>
                            <span data-checkout-item-meta></span>
                        </td>
                        <td data-checkout-item-price></td>
                        <td data-checkout-item-quantity></td>
                        <td><strong data-checkout-item-subtotal></strong></td>
                        <td>
                            <button type="button" data-checkout-remove>Remove</button>
                        </td>
                    </tr>
                </template>
            </div>

        </div>

        <aside class="checkout-summary" data-checkout-summary hidden>
            <p class="offers-section__kicker mb-1">Order summary</p>
            <h2>Summary</h2>

            <div class="checkout-summary__row">
                <span>Subtotal</span>
                <strong data-checkout-subtotal>0,00 €</strong>
            </div>

            <div class="checkout-summary__row">
                <span>Payment provider</span>
                <span>Stripe</span>
            </div>

            <div class="checkout-summary__total">
                <span>Total</span>
                <strong data-checkout-total>0,00 €</strong>
            </div>

            <button class="btn btn-dark rounded-pill w-100 checkout-summary__button" type="button" data-checkout-order disabled>
                Place order
            </button>

            <p class="checkout-summary__note">
                Stripe redirection will be plugged here later. For now, this button is intentionally inactive.
            </p>
        </aside>
    </section>
{% endblock %}

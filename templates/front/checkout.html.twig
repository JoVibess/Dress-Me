{% extends 'front/base.html.twig' %}

{% block page_title %}{{ 'checkout.title'|trans }}{% endblock %}

{% block front_body %}
    <section class="checkout-hero text-center mx-auto">
        <p class="eyebrow">{{ 'checkout.eyebrow'|trans }}</p>
        <h1>{{ 'checkout.heading'|trans }}</h1>
        <p>
            {{ 'checkout.intro'|trans }}
        </p>
    </section>

    <section class="checkout-layout">
        <div class="checkout-main">
            <a class="btn btn-outline-dark rounded-pill px-4 checkout-back-link" href="{{ path('front_offers') }}">{{ 'checkout.back_to_offers'|trans }}</a>

            <div class="checkout-panel">
                <div class="checkout-panel__header">
                    <div>
                        <p class="offers-section__kicker mb-1">{{ 'checkout.cart_items'|trans }}</p>
                        <h2 class="mb-0">{{ 'checkout.selected_offers'|trans }}</h2>
                    </div>
                    <span class="checkout-panel__count">
                        <span data-checkout-count>0</span> {{ 'checkout.items_suffix'|trans }}
                    </span>
                </div>

                <p class="checkout-empty" data-checkout-empty>
                    {{ 'checkout.empty'|trans }}
                    <a href="{{ path('front_offers') }}">{{ 'checkout.back_to_offers'|trans }}</a>
                </p>

                <div class="checkout-table-wrap">
                    <table class="checkout-table">
                        <thead>
                            <tr>
                                <th scope="col">{{ 'checkout.table.offer'|trans }}</th>
                                <th scope="col">{{ 'checkout.table.unit_price'|trans }}</th>
                                <th scope="col">{{ 'checkout.table.qty'|trans }}</th>
                                <th scope="col">{{ 'checkout.table.subtotal'|trans }}</th>
                                <th scope="col"><span class="visually-hidden">{{ 'checkout.table.actions'|trans }}</span></th>
                            </tr>
                        </thead>
                        <tbody data-checkout-list></tbody>
                    </table>
                </div>

                <template data-checkout-item-template>
                    <tr data-checkout-item>
                        <td>
                            <strong data-checkout-item-name></strong>
                            <span data-checkout-item-meta></span>
                        </td>
                        <td data-checkout-item-price></td>
                        <td data-checkout-item-quantity></td>
                        <td><strong data-checkout-item-subtotal></strong></td>
                        <td>
                            <button type="button" data-checkout-remove>{{ 'common.remove'|trans }}</button>
                        </td>
                    </tr>
                </template>
            </div>

        </div>

        <aside class="checkout-summary" data-checkout-summary hidden>
            <p class="offers-section__kicker mb-1">{{ 'checkout.summary.kicker'|trans }}</p>
            <h2>{{ 'checkout.summary.title'|trans }}</h2>

            <div class="checkout-summary__row">
                <span>{{ 'checkout.summary.subtotal'|trans }}</span>
                <strong data-checkout-subtotal>0,00 €</strong>
            </div>

            <div class="checkout-summary__row">
                <span>{{ 'checkout.summary.payment_provider'|trans }}</span>
                <span>Stripe</span>
            </div>

            <div class="checkout-summary__total">
                <span>{{ 'common.total'|trans }}</span>
                <strong data-checkout-total>0,00 €</strong>
            </div>

            <button class="btn btn-dark rounded-pill w-100 checkout-summary__button" type="button" data-checkout-order disabled>
                {{ 'checkout.summary.place_order'|trans }}
            </button>

            <p class="checkout-summary__note">
                {{ 'checkout.summary.note'|trans }}
            </p>
        </aside>
    </section>
{% endblock %}

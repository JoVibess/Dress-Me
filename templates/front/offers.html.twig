{% extends 'front/base.html.twig' %}

{% block page_title %}Offers{% endblock %}

{% block front_body %}
    <section class="offers-hero text-center mx-auto">
        <p class="eyebrow">DressMe pricing</p>
        <h1>Choose the credit plan that fits your store.</h1>
        <p>
            Subscriptions are made for recurring virtual try-on usage.
            One-time packs are useful when you need extra credits for a campaign or a product launch.
        </p>
    </section>

    <section class="offers-section">
        <div class="offers-section__header d-flex align-items-end justify-content-between gap-3 mb-4">
            <div>
                <p class="offers-section__kicker mb-1">Recurring credits</p>
                <h2 class="mb-0">Subscriptions</h2>
            </div>

            <div class="billing-switch" data-subscription-switcher role="group" aria-label="Subscription billing period">
                <button class="billing-switch__button is-active" type="button" data-billing-filter="monthly" aria-pressed="true">
                    Monthly
                </button>
                <button class="billing-switch__button" type="button" data-billing-filter="annual" aria-pressed="false">
                    Annually
                </button>
            </div>
        </div>

        <div class="row g-4" data-subscription-offers>
            {% for offer in subscription_offers %}
                {% set billing_period = offer.durationInMonths == 12 ? 'annual' : 'monthly' %}

                <div class="col-12 col-md-6 col-xl-4" data-billing-period="{{ billing_period }}" {% if billing_period != 'monthly' %}hidden{% endif %}>
                    <article class="offer-card h-100">
                        <div>
                            <span class="offer-card__badge">{{ billing_period == 'annual' ? 'Annual subscription' : 'Subscription' }}</span>
                            <h3>{{ offer.name }}</h3>
                            <p class="offer-card__description">{{ offer.description }}</p>
                        </div>

                        <div class="offer-card__details">
                            <p class="offer-price">{{ offer.price|number_format(2, '.', ' ') }} €</p>
                            <p class="offer-card__credits">
                                {{ offer.creditAmount }} credits / {{ offer.durationInMonths }} {{ offer.durationInMonths > 1 ? 'months' : 'month' }}
                            </p>
                        </div>

                        <button
                            class="btn btn-dark rounded-pill w-100"
                            type="button"
                            data-cart-add
                            data-offer-id="{{ offer.id }}"
                            data-offer-name="{{ offer.name }}"
                            data-offer-price="{{ offer.price }}"
                            data-offer-credits="{{ offer.creditAmount }}"
                            data-offer-duration="{{ offer.durationInMonths }}"
                        >
                            Add to cart
                        </button>
                    </article>
                </div>
            {% else %}
                <div class="col-12">
                    <p>No subscription offer is available yet.</p>
                </div>
            {% endfor %}
        </div>
    </section>

    <section class="offers-section">
        <div class="d-flex align-items-end justify-content-between gap-3 mb-4">
            <div>
                <p class="offers-section__kicker mb-1">Flexible packs</p>
                <h2 class="mb-0">One-time credit packs</h2>
            </div>
        </div>

        <div class="row g-4">
            {% for offer in one_time_offers %}
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="offer-card h-100">
                        <div>
                            <span class="offer-card__badge offer-card__badge--light">One-time</span>
                            <h3>{{ offer.name }}</h3>
                            <p class="offer-card__description">{{ offer.description }}</p>
                        </div>

                        <div class="offer-card__details">
                            <p class="offer-price">
                                {% if offer.price == '0.00' %}
                                    Free
                                {% else %}
                                    {{ offer.price|number_format(2, '.', ' ') }} €
                                {% endif %}
                            </p>
                            <p class="offer-card__credits">{{ offer.creditAmount }} credits</p>
                        </div>

                        <button
                            class="btn btn-outline-dark rounded-pill w-100"
                            type="button"
                            data-cart-add
                            data-offer-id="{{ offer.id }}"
                            data-offer-name="{{ offer.name }}"
                            data-offer-price="{{ offer.price }}"
                            data-offer-credits="{{ offer.creditAmount }}"
                            data-offer-duration=""
                        >
                            Add to cart
                        </button>
                    </article>
                </div>
            {% else %}
                <div class="col-12">
                    <p>No one-time credit pack is available yet.</p>
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}

{% extends 'front/base.html.twig' %}

{% block page_title %}{{ 'offers.title'|trans }}{% endblock %}

{% block front_body %}
    <section class="offers-hero text-center mx-auto">
        <p class="eyebrow">{{ 'offers.eyebrow'|trans }}</p>
        <h1>{{ 'offers.heading'|trans }}</h1>
        <p>
            {{ 'offers.intro'|trans }}
        </p>
    </section>

    <section class="offers-section">
        <div class="offers-section__header d-flex align-items-end justify-content-between gap-3 mb-4">
            <div>
                <p class="offers-section__kicker mb-1">{{ 'offers.recurring_credits'|trans }}</p>
                <h2 class="mb-0">{{ 'offers.subscriptions'|trans }}</h2>
            </div>

            <div class="billing-switch" data-subscription-switcher role="group" aria-label="{{ 'offers.billing_period'|trans }}">
                <button class="billing-switch__button is-active" type="button" data-billing-filter="monthly" aria-pressed="true">
                    {{ 'offers.monthly'|trans }}
                </button>
                <button class="billing-switch__button" type="button" data-billing-filter="annual" aria-pressed="false">
                    {{ 'offers.annually'|trans }}
                </button>
            </div>
        </div>

        <div class="row g-4" data-subscription-offers>
            {% for offer in subscription_offers %}
                {% set billing_period = offer.durationInMonths == 12 ? 'annual' : 'monthly' %}

                <div class="col-12 col-md-6 col-xl-4" data-billing-period="{{ billing_period }}" {% if billing_period != 'monthly' %}hidden{% endif %}>
                    <article class="offer-card h-100">
                        <div>
                            <span class="offer-card__badge">{{ billing_period == 'annual' ? 'offers.annual_subscription'|trans : 'offers.subscription'|trans }}</span>
                            <h3>{{ offer.name }}</h3>
                            <p class="offer-card__description">{{ offer.description }}</p>
                        </div>

                        <div class="offer-card__details">
                            <p class="offer-price">{{ offer.price|number_format(2, '.', ' ') }} €</p>
                            <p class="offer-card__credits">
                                {{ offer.creditAmount }} credits / {{ offer.durationInMonths }} {{ offer.durationInMonths > 1 ? 'common.months'|trans : 'common.month'|trans }}
                            </p>
                        </div>

                        <button
                            class="btn btn-dark rounded-pill w-100"
                            type="button"
                            data-cart-add
                            data-offer-id="{{ offer.id }}"
                            data-offer-name="{{ offer.name }}"
                            data-offer-price="{{ offer.price }}"
                            data-offer-credits="{{ offer.creditAmount }}"
                            data-offer-duration="{{ offer.durationInMonths }}"
                        >
                            {{ 'offers.add_to_cart'|trans }}
                        </button>
                    </article>
                </div>
            {% else %}
                <div class="col-12">
                    <p>{{ 'offers.no_subscription'|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </section>

    <section class="offers-section">
        <div class="d-flex align-items-end justify-content-between gap-3 mb-4">
            <div>
                <p class="offers-section__kicker mb-1">{{ 'offers.flexible_packs'|trans }}</p>
                <h2 class="mb-0">{{ 'offers.one_time_packs'|trans }}</h2>
            </div>
        </div>

        <div class="row g-4">
            {% for offer in one_time_offers %}
                <div class="col-12 col-md-6 col-xl-4">
                    <article class="offer-card h-100">
                        <div>
                            <span class="offer-card__badge offer-card__badge--light">{{ 'offers.one_time'|trans }}</span>
                            <h3>{{ offer.name }}</h3>
                            <p class="offer-card__description">{{ offer.description }}</p>
                        </div>

                        <div class="offer-card__details">
                            <p class="offer-price">
                                {% if offer.price == '0.00' %}
                                    {{ 'common.free'|trans }}
                                {% else %}
                                    {{ offer.price|number_format(2, '.', ' ') }} €
                                {% endif %}
                            </p>
                            <p class="offer-card__credits">{{ offer.creditAmount }} credits</p>
                        </div>

                        <button
                            class="btn btn-outline-dark rounded-pill w-100"
                            type="button"
                            data-cart-add
                            data-offer-id="{{ offer.id }}"
                            data-offer-name="{{ offer.name }}"
                            data-offer-price="{{ offer.price }}"
                            data-offer-credits="{{ offer.creditAmount }}"
                            data-offer-duration=""
                        >
                            {{ 'offers.add_to_cart'|trans }}
                        </button>
                    </article>
                </div>
            {% else %}
                <div class="col-12">
                    <p>{{ 'offers.no_one_time'|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </section>
{% endblock %}
